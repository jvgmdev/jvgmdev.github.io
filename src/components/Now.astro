---
const items = [
  {
    label: 'Work',
    title: 'Leading ITSM delivery at DXC',
    sub: 'Technical governance & solution design',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
    updated: 'updated 1d ago',
  },
  {
    label: 'Homelab',
    title: 'Tuning local LLM voice pipeline',
    sub: 'Ollama + Whisper on Pi cluster',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
    updated: 'updated 3d ago',
  },
  {
    label: 'Reading',
    title: 'A Short History of Nearly Everything',
    sub: 'Bill Bryson',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>`,
    updated: 'updated 5d ago',
  },
  {
    label: 'Tinkering',
    title: 'Zigbee sensor mesh for the apartment',
    sub: 'ESP32 + CC2652 coordinator',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/></svg>`,
    updated: 'updated 2d ago',
  },
];
---

<section class="now section" id="now">
  <div class="container">
    <p class="section-eyebrow">/ NOW</p>

    <div class="now__grid">
      {items.map((item) => (
        <div class="now__card">
          <div class="now__card-top">
            <div class="now__icon" set:html={item.icon} />
            <span class="now__label">{item.label}</span>
          </div>
          <div class="now__card-body">
            <div class="now__title">{item.title}</div>
            <div class="now__sub">{item.sub}</div>
          </div>
          <div class="now__timestamp">{item.updated}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .now {
    padding: 64px 0;
  }

  .now__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .now__card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease);
  }

  .now__card:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
  }

  .now__card-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .now__icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--paper-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .now__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .now__title {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .now__sub {
    font-size: 13px;
    color: var(--muted);
  }

  .now__timestamp {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 900px) {
    .now__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .now__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
