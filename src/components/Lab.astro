---
const projects = [
  {
    title: 'Smart Home Stack',
    sub: 'home-automation',
    description: 'Fully automated home running Home Assistant, Node-RED, ESPHome, and Zigbee. Custom automations backed by MariaDB, dashboards, and secure remote access.',
    chips: ['Home Assistant', 'Node-RED', 'ESPHome', 'Zigbee', 'MariaDB', 'Raspberry Pi'],
    status: 'Online',
    uptime: '142d uptime',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'Local LLM & Voice Assistant',
    sub: 'ai-pipeline',
    description: 'Self-hosted Ollama running LLMs on local hardware. Integrated into a distributed, fully offline voice assistant pipeline.',
    chips: ['Ollama', 'Python', 'Raspberry Pi', 'Linux'],
    status: 'Building',
    uptime: '',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
  },
  {
    title: 'Homelab & Self-hosting',
    sub: 'infrastructure',
    description: 'Raspberry Pi cluster with Tailscale VPN mesh. Self-managed services focused on privacy, control, and reliability.',
    chips: ['Tailscale', 'Raspberry Pi', 'Docker', 'Linux'],
    status: 'Online',
    uptime: '89d uptime',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`,
  },
];
---

<section class="lab section" id="lab">
  <div class="container">
    <p class="section-eyebrow">02 / Lab</p>
    <h2 class="section-title">Things I <span class="serif-accent">build</span> after the dayjob</h2>

    <div class="lab__grid">
      {projects.map((project) => (
        <div class="lab__card">
          <div class="lab__icon" set:html={project.icon} />
          <h3 class="lab__title">{project.title}</h3>
          <span class="lab__sub">{project.sub}</span>
          <p class="lab__desc">{project.description}</p>
          <div class="lab__chips">
            {project.chips.map((chip) => (
              <span class="chip">{chip}</span>
            ))}
          </div>
          <div class="lab__status-bar">
            <span class={`lab__status-dot ${project.status === 'Online' ? 'lab__status-dot--online' : 'lab__status-dot--building'}`}></span>
            <span class="lab__status-text">
              {project.status}
              {project.uptime && ` · ${project.uptime}`}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lab__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .lab__card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 28px;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }

  .lab__card:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-card);
  }

  .lab__icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: var(--paper-2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    margin-bottom: 16px;
    transition: background 0.25s var(--ease), color 0.25s var(--ease);
  }

  .lab__card:hover .lab__icon {
    background: var(--accent);
    color: #fff;
  }

  .lab__title {
    font-size: 17px;
    font-weight: 500;
    margin-bottom: 4px;
  }

  .lab__sub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 12px;
  }

  .lab__desc {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
    flex: 1;
    margin-bottom: 16px;
  }

  .lab__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
  }

  .lab__status-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: 14px;
    border-top: 1px dashed var(--border);
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .lab__status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .lab__status-dot--online {
    background: var(--green);
    box-shadow: 0 0 0 3px rgba(57, 184, 120, 0.15);
  }

  .lab__status-dot--building {
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .lab__status-text {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .lab__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .lab__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
