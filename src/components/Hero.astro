---
---

<section class="hero section" id="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__inner container">
    <!-- Left column -->
    <div class="hero__left">
      <div class="hero__eyebrow">
        <span class="hero__eyebrow-dot"></span>
        <span>ServiceNow Technical Lead · Homelab tinkerer</span>
      </div>

      <h1 class="hero__headline">
        Designing systems that <span class="serif-accent">think</span>, and homes that <span class="serif-accent">listen</span>.
      </h1>

      <p class="hero__intro">
        I'm Juan, a Technical Lead at DXC building enterprise platforms on ServiceNow. After hours I run a homelab full of Raspberry Pis, local LLMs, and far too many Zigbee sensors.
      </p>

      <div class="hero__cta-row">
        <a href="#experience" class="hero__cta-primary">
          See my work
          <span class="hero__cta-arrow">→</span>
        </a>
        <a href="#contact" class="hero__cta-secondary">Get in touch</a>
      </div>

      <div class="hero__meta">
        <div class="hero__meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero__meta-icon"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span><strong>Málaga,</strong> Andalucía</span>
        </div>
        <div class="hero__meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero__meta-icon"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <strong>jvgm.dev@gmail.com</strong>
        </div>
        <div class="hero__meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hero__meta-icon"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          <span><strong>github</strong>/jvgmdev</span>
        </div>
      </div>
    </div>

    <!-- Right column (sidebar) -->
    <div class="hero__sidebar">
      <!-- Now card -->
      <div class="hero__now-card">
        <div class="hero__now-header">
          <span class="mono-label">/ now</span>
          <span class="hero__now-dot pulse-accent"></span>
        </div>
        <div class="hero__now-list">
          <div class="hero__now-item">
            <div class="hero__now-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div>
              <div class="hero__now-title">Leading ITSM delivery at DXC</div>
              <div class="hero__now-sub">Technical governance · solution design</div>
            </div>
          </div>
          <div class="hero__now-item">
            <div class="hero__now-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
            </div>
            <div>
              <div class="hero__now-title">Tuning a local LLM voice assistant</div>
              <div class="hero__now-sub">Ollama on Pi cluster · fully offline</div>
            </div>
          </div>
          <div class="hero__now-item">
            <div class="hero__now-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
            </div>
            <div>
              <div class="hero__now-title">Reading: A Short History of Nearly Everything</div>
              <div class="hero__now-sub">Bill Bryson</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Stats row -->
      <div class="hero__stats">
        <div class="hero__stat">
          <div class="hero__stat-value">5+</div>
          <div class="hero__stat-label">years on ServiceNow</div>
        </div>
        <div class="hero__stat">
          <div class="hero__stat-value">4</div>
          <div class="hero__stat-label">platform certifications</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 48px;
    padding-bottom: 96px;
  }

  .hero__glow {
    position: absolute;
    right: -120px;
    top: 60px;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(184, 89, 59, 0.18), transparent 70%);
    filter: blur(20px);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: flex-start;
  }

  /* Left column */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--muted);
    padding: 6px 14px;
    background: var(--card);
    border-radius: 100px;
    border: 1px solid var(--border);
    margin-bottom: 32px;
  }

  .hero__eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .hero__headline {
    font-family: var(--sans);
    font-weight: 500;
    font-size: clamp(44px, 6.4vw, 80px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin-bottom: 32px;
    max-width: 720px;
  }

  .hero__intro {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 540px;
    margin-bottom: 36px;
  }

  /* CTAs */
  .hero__cta-row {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .hero__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.25s var(--ease);
  }

  .hero__cta-primary:hover {
    background: var(--accent);
  }

  .hero__cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    font-size: 12px;
    transition: transform 0.25s var(--ease);
  }

  .hero__cta-primary:hover .hero__cta-arrow {
    transform: rotate(-45deg) translate(2px, -2px);
  }

  .hero__cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    transition: border-color 0.25s var(--ease);
  }

  .hero__cta-secondary:hover {
    border-color: var(--border-strong);
  }

  /* Meta row */
  .hero__meta {
    display: flex;
    gap: 32px;
    align-items: center;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 13px;
    color: var(--muted);
    flex-wrap: wrap;
  }

  .hero__meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero__meta-item strong {
    color: var(--ink);
    font-weight: 500;
  }

  .hero__meta-icon {
    color: var(--accent);
    flex-shrink: 0;
  }

  /* Sidebar */
  .hero__sidebar {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero__now-card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px;
  }

  .hero__now-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .hero__now-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .hero__now-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero__now-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .hero__now-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--paper-2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--accent);
  }

  .hero__now-title {
    font-size: 13.5px;
    color: var(--ink);
    font-weight: 500;
    margin-bottom: 2px;
  }

  .hero__now-sub {
    font-size: 12px;
    color: var(--muted);
  }

  /* Stats */
  .hero__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .hero__stat {
    background: var(--card);
    border-radius: 16px;
    border: 1px solid var(--border);
    padding: 18px 18px 16px;
  }

  .hero__stat-value {
    font-family: var(--serif);
    font-size: 36px;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 6px;
    letter-spacing: -0.02em;
  }

  .hero__stat-label {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .hero__sidebar {
      max-width: 480px;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 32px;
      padding-bottom: 64px;
    }

    .hero__meta {
      gap: 16px;
    }
  }
</style>
