---
const links = [
  { label: 'Index', href: '#hero' },
  { label: 'Work', href: '#experience' },
  { label: 'Lab', href: '#lab' },
  { label: 'Now', href: '#now' },
  { label: 'Contact', href: '#contact' },
];
---

<nav class="nav" id="site-nav" aria-label="Main navigation">
  <div class="nav__inner">
    <!-- Brand -->
    <a href="#hero" class="nav__brand">
      <div class="nav__avatar">JV</div>
      <div class="nav__brand-text">
        <span class="nav__name">Juan Victor González</span>
        <span class="nav__location">Málaga, Spain</span>
      </div>
    </a>

    <!-- Pill nav (desktop) -->
    <div class="nav__links" role="list">
      {links.map((link, i) => (
        <a
          href={link.href}
          class:list={['nav__link', { 'nav__link--active': i === 0 }]}
          data-nav-link
          role="listitem"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="nav__right">
      <span class="nav__lang">
        <span class="nav__lang-active">EN</span> / <button class="nav__lang-disabled" disabled title="Coming soon">es</button>
      </span>
      <div class="nav__status">
        <span class="nav__status-dot pulse-green"></span>
        <span class="nav__status-label">Available</span>
      </div>

      <!-- Hamburger (mobile) -->
      <button class="nav__hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    {links.map((link) => (
      <a href={link.href} class="nav__mobile-link" data-mobile-link>{link.label}</a>
    ))}
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--paper);
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease);
    border-bottom: 1px solid transparent;
  }

  .nav--scrolled {
    background: rgba(250, 247, 242, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--border);
  }

  .nav__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 16px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Brand */
  .nav__brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .nav__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #d8c8b3 0%, #b8593b 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .nav__brand-text {
    display: flex;
    flex-direction: column;
  }

  .nav__name {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
  }

  .nav__location {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.2;
  }

  /* Pill nav links */
  .nav__links {
    display: flex;
    gap: 4px;
    background: var(--card);
    padding: 4px;
    border-radius: 100px;
    border: 1px solid var(--border);
    font-size: 13px;
  }

  .nav__link {
    padding: 8px 16px;
    border-radius: 100px;
    color: var(--muted);
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
    white-space: nowrap;
  }

  .nav__link:hover {
    color: var(--ink);
  }

  .nav__link--active {
    background: var(--ink);
    color: var(--paper);
  }

  /* Right side */
  .nav__right {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    color: var(--muted);
    flex-shrink: 0;
  }

  .nav__lang {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  .nav__lang-active {
    color: var(--ink);
    font-weight: 500;
  }

  .nav__lang-disabled {
    color: var(--muted);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    cursor: not-allowed;
    padding: 0;
  }

  .nav__status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 100px;
    background: var(--card);
    border: 1px solid var(--border);
  }

  .nav__status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }

  .nav__status-label {
    color: var(--ink);
    font-weight: 500;
    white-space: nowrap;
  }

  /* Hamburger */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    width: 32px;
  }

  .nav__hamburger span {
    display: block;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.25s var(--ease), opacity 0.25s var(--ease);
  }

  .nav__hamburger--open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__hamburger--open span:nth-child(2) { opacity: 0; }
  .nav__hamburger--open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown */
  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: 0 48px 24px;
    gap: 4px;
  }

  .nav__mobile--open {
    display: flex;
  }

  .nav__mobile-link {
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    font-size: 15px;
    color: var(--ink-2);
    transition: background 0.15s var(--ease);
  }

  .nav__mobile-link:hover {
    background: var(--paper-2);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .nav__links { display: none; }
    .nav__hamburger { display: flex; }
    .nav__inner { padding: 16px 24px; }
    .nav__mobile { padding: 0 24px 24px; }
  }

  @media (max-width: 640px) {
    .nav__brand-text { display: none; }
    .nav__lang { display: none; }
  }
</style>

<script>
  // Sticky nav scroll effect
  const nav = document.getElementById('site-nav')!;
  const onScroll = () => {
    nav.classList.toggle('nav--scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Active section detection
  const sections = document.querySelectorAll<HTMLElement>('.section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navLinks.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('nav__link--active', isActive);
          });
        }
      });
    },
    { rootMargin: '-20% 0px -60% 0px' }
  );

  sections.forEach((section) => observer.observe(section));

  // Mobile hamburger
  const hamburger = document.getElementById('nav-hamburger')!;
  const mobileMenu = document.getElementById('nav-mobile')!;

  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('nav__hamburger--open');
    mobileMenu.classList.toggle('nav__mobile--open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('nav__hamburger--open');
      mobileMenu.classList.remove('nav__mobile--open');
      hamburger.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
