---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact__card">
      <div class="contact__bloom" aria-hidden="true"></div>

      <!-- Left -->
      <div class="contact__body">
        <div class="contact__eyebrow">
          <span class="contact__green-dot pulse-green"></span>
          <span>◆ LET'S TALK</span>
        </div>

        <h2 class="contact__headline">
          Let's build something <span class="contact__accent">good</span> together.
        </h2>

        <p class="contact__intro">
          Open to ServiceNow consulting, freelance engagements, and technical advisory. Based in Málaga, available remotely worldwide.
        </p>

        <div class="contact__cta-row">
          <a href="mailto:jvgm.dev@gmail.com" class="contact__cta-primary">
            Send an email
            <span class="contact__cta-arrow">→</span>
          </a>
          <a href="https://www.linkedin.com/in/juanvdev/" target="_blank" rel="noopener noreferrer" class="contact__cta-secondary">
            Open LinkedIn
          </a>
        </div>
      </div>

      <!-- Right: Glass panel -->
      <div class="contact__panel">
        <div class="contact__links">
          <a href="mailto:jvgm.dev@gmail.com" class="contact__link-row">
            <span class="contact__link-label">Email</span>
            <span class="contact__link-value">jvgm.dev@gmail.com</span>
            <svg class="contact__link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/juanvdev/" target="_blank" rel="noopener noreferrer" class="contact__link-row">
            <span class="contact__link-label">LinkedIn</span>
            <span class="contact__link-value">/in/juanvdev</span>
            <svg class="contact__link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
          <a href="https://github.com/jvgmdev" target="_blank" rel="noopener noreferrer" class="contact__link-row">
            <span class="contact__link-label">GitHub</span>
            <span class="contact__link-value">jvgmdev</span>
            <svg class="contact__link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
          <a href="/rss.xml" class="contact__link-row">
            <span class="contact__link-label">RSS / Feed</span>
            <span class="contact__link-value">Subscribe</span>
            <svg class="contact__link-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__card {
    background: linear-gradient(135deg, var(--ink) 0%, #2a2520 100%);
    border-radius: 32px;
    padding: 72px 56px;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    position: relative;
    overflow: hidden;
    color: var(--paper);
  }

  .contact__bloom {
    position: absolute;
    bottom: -80px;
    right: -40px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184, 89, 59, 0.25), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }

  /* Left body */
  .contact__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.5);
    margin-bottom: 24px;
  }

  .contact__green-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }

  .contact__headline {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--paper);
  }

  .contact__accent {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    color: #e8a082;
    letter-spacing: -0.02em;
  }

  .contact__intro {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(250, 247, 242, 0.55);
    max-width: 480px;
    margin-bottom: 32px;
  }

  .contact__cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    position: relative;
  }

  .contact__cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: var(--paper);
    color: var(--ink);
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    transition: background 0.25s var(--ease);
  }

  .contact__cta-primary:hover {
    background: #e8dfd0;
  }

  .contact__cta-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-size: 12px;
    transition: transform 0.25s var(--ease);
  }

  .contact__cta-primary:hover .contact__cta-arrow {
    transform: rotate(-45deg) translate(2px, -2px);
  }

  .contact__cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 14px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    color: var(--paper);
    border: 1px solid rgba(250, 247, 242, 0.15);
    transition: border-color 0.25s var(--ease);
  }

  .contact__cta-secondary:hover {
    border-color: rgba(250, 247, 242, 0.35);
  }

  /* Glass panel */
  .contact__panel {
    background: rgba(250, 247, 242, 0.08);
    border: 1px solid rgba(250, 247, 242, 0.1);
    border-radius: var(--radius);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 8px;
    position: relative;
    align-self: center;
  }

  .contact__links {
    display: flex;
    flex-direction: column;
  }

  .contact__link-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 16px;
    border-radius: 12px;
    font-size: 14px;
    color: var(--paper);
    transition: background 0.2s var(--ease);
  }

  .contact__link-row:hover {
    background: rgba(250, 247, 242, 0.06);
  }

  .contact__link-label {
    font-weight: 500;
    min-width: 70px;
  }

  .contact__link-value {
    flex: 1;
    color: rgba(250, 247, 242, 0.5);
    font-size: 13px;
  }

  .contact__link-arrow {
    color: rgba(250, 247, 242, 0.3);
    transition: transform 0.2s var(--ease), color 0.2s var(--ease);
    flex-shrink: 0;
  }

  .contact__link-row:hover .contact__link-arrow {
    transform: translate(2px, -2px);
    color: rgba(250, 247, 242, 0.6);
  }

  @media (max-width: 900px) {
    .contact__card {
      grid-template-columns: 1fr;
      padding: 48px 32px;
    }
  }

  @media (max-width: 480px) {
    .contact__card {
      padding: 36px 24px;
      border-radius: 24px;
    }
  }
</style>
