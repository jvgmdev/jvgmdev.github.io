---
import { getCollection } from 'astro:content';

const notes = await getCollection('notes');
const sortedNotes = notes.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<section class="notes section" id="notes">
  <div class="container">
    <p class="section-eyebrow">04 / Notes</p>
    <h2 class="section-title">Writing on systems, self-hosting & the trade</h2>

    <div class="notes__grid">
      {sortedNotes.map((note) => (
        <a href={`/notes/${note.id}`} class="notes__card">
          <div class="notes__meta">
            <span>{note.data.date}</span>
            <span>·</span>
            <span>{note.data.readTime}</span>
            <span>·</span>
            <span class="notes__category">{note.data.category}</span>
          </div>
          <h3 class="notes__title">{note.data.title}</h3>
          <p class="notes__excerpt">{note.data.excerpt}</p>
          <span class="notes__link">
            Read note <span class="notes__arrow">→</span>
          </span>
          {note.data.placeholder && (
            <span class="notes__placeholder-badge">Placeholder</span>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .notes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .notes__card {
    background: var(--card);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    padding: 24px;
    display: flex;
    flex-direction: column;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease), box-shadow 0.25s var(--ease);
    position: relative;
  }

  .notes__card:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-card);
  }

  .notes__meta {
    display: flex;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .notes__category {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .notes__title {
    font-size: 19px;
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--ink);
  }

  .notes__excerpt {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.55;
    flex: 1;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .notes__link {
    font-size: 14px;
    color: var(--accent);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .notes__arrow {
    transition: transform 0.2s var(--ease);
  }

  .notes__card:hover .notes__arrow {
    transform: translateX(4px);
  }

  .notes__placeholder-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--paper-2);
    padding: 3px 8px;
    border-radius: 100px;
  }

  @media (max-width: 900px) {
    .notes__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .notes__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
